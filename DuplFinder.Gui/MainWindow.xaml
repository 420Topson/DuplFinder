<Window x:Class="DuplFinder.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DuplFinder GUI MVP" Height="900" Width="1280" MinHeight="720" MinWidth="1040"
        Background="#f3f4f6">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Header="Output Preview / read-only console pane" Grid.Row="0" Height="150" Margin="0,0,0,6">
            <TextBox x:Name="OutputTextBox"
                     FontFamily="Consolas"
                     FontSize="13"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     AcceptsTab="False"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Background="#111827"
                     Foreground="#d1d5db"
                     BorderThickness="0"
                     Padding="8" />
        </GroupBox>

        <Border Grid.Row="1" BorderBrush="#d1d5db" BorderThickness="1" Background="White" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Persistent Command Preview" FontWeight="Bold" Margin="0,0,0,3" />
                <TextBlock x:Name="ReadyTextBlock" Grid.Row="1" Foreground="#92400e" Margin="0,0,0,4" />
                <TextBox x:Name="CommandPreviewTextBox" Grid.Row="2" FontFamily="Consolas" FontSize="12" IsReadOnly="True"
                         Height="118" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                    <Button x:Name="RunCommandButton" Content="Run" MinWidth="140" Click="OnRunCommand" MouseEnter="OnRunButtonMouseEnter" Margin="0,0,8,0" />
                    <Button x:Name="CancelButton" Content="Cancel" Width="90" Click="OnCancelCommand" IsEnabled="False" Margin="0,0,8,0" />
                    <Button Content="Copy preview" Width="120" Click="OnCopyCommand" Margin="0,0,8,0" />
                    <Button Content="Clear output" Width="110" Click="OnClearOutput" Margin="0,0,8,0" />
                    <Button Content="Open output folder" Width="150" Click="OnOpenOutputFolder" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="2" SelectionChanged="OnControlsChanged">
            <TabItem Header="Scan">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Available drives" FontWeight="Bold" Margin="0,0,0,4" />
                        <ListBox x:Name="DriveListBox" Height="135" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Refresh drives" Click="OnRefreshDrives" Margin="0,0,8,0" />
                            <Button Content="Choose folder..." Click="OnChooseFolder" />
                        </StackPanel>

                        <TextBlock Text="Selected scan targets" FontWeight="Bold" Margin="0,10,0,4" />
                        <ListBox x:Name="SelectedTargetsListBox" Height="115" SelectionChanged="OnControlsChanged" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Remove selected" Click="OnRemoveSelectedTarget" Margin="0,0,8,0" />
                            <Button Content="Clear all" Click="OnClearTargets" />
                        </StackPanel>
                        <TextBlock x:Name="TargetWarningTextBlock" Foreground="#92400e" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Scan settings" FontWeight="Bold" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Database:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox x:Name="DbPathTextBox" Grid.Column="1" TextChanged="OnControlsChanged" />
                            <Button Grid.Column="2" Content="Browse..." Click="OnBrowseDb" Margin="8,0,0,0" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Profile:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox x:Name="ProfileComboBox" Width="190" SelectionChanged="OnControlsChanged">
                                <ComboBoxItem Content="HDD / older PC" Tag="hdd" />
                                <ComboBoxItem Content="SATA SSD / balanced" Tag="sata-ssd" IsSelected="True" />
                                <ComboBoxItem Content="NVMe / fast PC" Tag="nvme" />
                            </ComboBox>
                            <CheckBox x:Name="RecordSkippedCheckBox" Content="Record skipped" Margin="18,0,0,0" Checked="OnControlsChanged" Unchecked="OnControlsChanged" />
                            <CheckBox x:Name="FollowReparseCheckBox" Content="Follow reparse points" Margin="18,0,0,0" Checked="OnControlsChanged" Unchecked="OnControlsChanged" />
                        </StackPanel>

                        <TextBlock Text="DuplFinder scans selected file types only. System folders such as Windows are skipped by default. Files with no extension are skipped by default unless explicitly enabled. Exact duplicates are detected by file size + full SHA-256."
                                   TextWrapping="Wrap" Foreground="#374151" Margin="0,8,0,4" />
                        <TextBlock x:Name="FileTypeCountTextBlock" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ScrollViewer Height="185" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="FileTypeGroupsPanel" />
                        </ScrollViewer>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock x:Name="MinSizeLabel" Text="Minimum file size to scan:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <ComboBox x:Name="MinSizeComboBox" Width="120" SelectionChanged="OnControlsChanged">
                                <ComboBoxItem Content="0 B" IsSelected="True" />
                                <ComboBoxItem Content="1 KB" />
                                <ComboBoxItem Content="10 KB" />
                                <ComboBoxItem Content="100 KB" />
                                <ComboBoxItem Content="1 MB" />
                                <ComboBoxItem Content="10 MB" />
                                <ComboBoxItem Content="100 MB" />
                                <ComboBoxItem Content="1 GB" />
                                <ComboBoxItem Content="10 GB" />
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="0 B = no --min-size filter; scan all selected file extensions."
                                   Foreground="#374151" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Duplicates">
                <StackPanel Margin="8">
                    <TextBlock Text="Find duplicate groups from the selected DuplFinder database." FontWeight="Bold" />
                    <TextBlock Text="DuplFinder reads duplicate information from the database created by Scan. CSV is optional export only. You do not need CSV to view or find duplicates."
                               TextWrapping="Wrap" Foreground="#374151" Margin="0,8,0,8" />
                    <GroupBox Header="Optional export" Padding="8" Margin="0,2,0,0">
                        <StackPanel>
                            <CheckBox x:Name="ExportCsvCheckBox" Content="Export duplicate results to CSV" Checked="OnControlsChanged" Unchecked="OnControlsChanged" />
                            <TextBlock Text="Leave this unchecked if you only want to view results in the output pane."
                                       TextWrapping="Wrap" Foreground="#374151" Margin="0,4,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="CsvExportLabel" Text="CSV output path:" VerticalAlignment="Center" Margin="0,0,8,0" IsEnabled="False" />
                                <TextBox x:Name="CsvPathTextBox" Grid.Column="1" TextChanged="OnControlsChanged" IsEnabled="False" />
                                <Button x:Name="CsvBrowseButton" Grid.Column="2" Content="Browse..." Click="OnBrowseCsv" Margin="8,0,0,0" IsEnabled="False" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <TabItem Header="Prestage Report">
                <StackPanel Margin="8">
                    <TextBlock Text="Generate a local HTML review report. It does not move or delete files." FontWeight="Bold" />
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HTML report:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="ReportPathTextBox" Grid.Column="1" TextChanged="OnControlsChanged" />
                        <Button Grid.Column="2" Content="Browse..." Click="OnBrowseReport" Margin="8,0,0,0" />
                    </Grid>
                    <CheckBox x:Name="ReportForceCheckBox" Content="Overwrite existing report (--force)" Margin="0,8,0,0" Checked="OnControlsChanged" Unchecked="OnControlsChanged" />
                    <CheckBox x:Name="OpenReportCheckBox" Content="Open report after generation" Margin="0,6,0,0" />
                    <Button x:Name="OpenReportButton" Content="Open report" Width="120" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnOpenReport" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Dupl Storage">
                <StackPanel Margin="8">
                    <TextBlock Text="Dupl Storage" FontWeight="Bold" />
                    <TextBlock Text="Dupl Storage is the safe local storage area used by DuplFinder for staged duplicate files. Files moved there can be restored using the generated manifest."
                               TextWrapping="Wrap" Foreground="#374151" Margin="0,4,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Run mode:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <RadioButton x:Name="StorageMoveModeRadio" Content="Move staged files" IsChecked="True" Checked="OnControlsChanged" Margin="0,0,14,0" />
                        <RadioButton x:Name="StorageRestoreModeRadio" Content="Restore" Checked="OnControlsChanged" Margin="0,0,14,0" />
                        <RadioButton x:Name="StorageCleanupModeRadio" Content="Cleanup" Checked="OnControlsChanged" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="1. Move staged files to Dupl Storage" Padding="8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Apply a browser-exported stage-plan.json. Dry-run is the default." TextWrapping="Wrap" Foreground="#374151" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Stage plan:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="StagePlanPathTextBox" Grid.Column="1" TextChanged="OnControlsChanged" />
                                    <Button Grid.Column="2" Content="Browse..." Click="OnBrowseStagePlan" Margin="8,0,0,0" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <RadioButton x:Name="ApplyDryRunRadio" Content="Move dry-run" IsChecked="True" Checked="OnControlsChanged" />
                                    <RadioButton x:Name="ApplyQuarantineRadio" Content="Move to Dupl Storage" Margin="18,0,0,0" Checked="OnControlsChanged" />
                                </StackPanel>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Storage folder:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="QuarantineFolderTextBox" Grid.Column="1" TextChanged="OnControlsChanged" />
                                    <Button Grid.Column="2" Content="Browse..." Click="OnBrowseQuarantineFolder" Margin="8,0,0,0" />
                                </Grid>
                                <TextBlock Text="KEEP files are never moved or modified." TextWrapping="Wrap" Foreground="#374151" Margin="0,8,0,0" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="2. Restore from Dupl Storage" Padding="8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Restore uses the Dupl Storage manifest to move files back to their original recorded paths. Run dry-run first to preview what would be restored."
                                           TextWrapping="Wrap" Foreground="#374151" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Manifest path:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="ManifestPathTextBox" Grid.Column="1" TextChanged="OnControlsChanged" />
                                    <Button Grid.Column="2" Content="Browse..." Click="OnBrowseManifest" Margin="8,0,0,0" />
                                </Grid>
                                <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                                    <RadioButton x:Name="UndoDryRunRadio" Content="Restore dry-run: preview restore only" IsChecked="True" Checked="OnControlsChanged" />
                                    <RadioButton x:Name="UndoRestoreRadio" Content="Restore: move files back from Dupl Storage" Margin="0,4,0,0" Checked="OnControlsChanged" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="3. Dupl Storage cleanup" Padding="8">
                            <StackPanel>
                                <TextBlock Text="Dry-run only previews what would be removed. It does not delete files."
                                           TextWrapping="Wrap" Foreground="#374151" Margin="0,0,0,6" />
                                <TextBlock Text="Confirm purge permanently deletes only validated files that are already inside the selected Dupl Storage session and listed in the manifest. It does not delete original duplicate paths or KEEP paths."
                                           TextWrapping="Wrap" Foreground="#374151" Margin="0,0,0,8" />
                                <StackPanel Orientation="Vertical">
                                    <RadioButton x:Name="PurgeDryRunRadio" Content="Dry-run only: preview Dupl Storage cleanup" IsChecked="True" Checked="OnControlsChanged" />
                                    <RadioButton x:Name="PurgeConfirmRadio" Content="Confirm purge: permanently delete files from Dupl Storage" Margin="0,4,0,0" Checked="OnControlsChanged" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem Header="Stats / Clean DB">
                <StackPanel Margin="8">
                    <TextBlock Text="Stats is read-only. Clean DB removes stale database records only; it does not delete files." FontWeight="Bold" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <RadioButton x:Name="StatsRadio" Content="Stats" IsChecked="True" Checked="OnControlsChanged" />
                        <RadioButton x:Name="CleanDbRadio" Content="Clean DB" Margin="18,0,0,0" Checked="OnControlsChanged" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Settings / Paths">
                <StackPanel Margin="8">
                    <TextBlock Text="Paths" FontWeight="Bold" />
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CLI executable:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="CliPathTextBox" Grid.Column="1" TextChanged="OnControlsChanged" />
                        <Button Grid.Column="2" Content="Browse..." Click="OnBrowseCli" Margin="8,0,0,0" />
                    </Grid>
                    <TextBlock Text="The GUI runs the existing CLI executable. It does not reimplement duplicate detection."
                               TextWrapping="Wrap" Foreground="#374151" Margin="0,10,0,0" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
